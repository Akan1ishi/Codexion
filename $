#include <sys/time.h>
#include <pthread.h>
#include <stdio.h>
#include <unistd.h>
#include <stdlib.h>
#include <stdbool.h>
typedef struct s_control
{
	struct timeval start_time;
	struct timeval current_time;
	pthread_mutex_t	mutex;
	pthread_t thread;
	long long time;
	int	nb_compiles;
	int	compile_goal;
	bool	active;
}	t_control;

typedef struct s_printer
{
	pthread_mutex_t	*mutex;
	pthread_t	thread;
	int	id;
	int rounds;
	long long *time;
	int	*nb_compiles;
	bool	*active;

}t_printer;

void	*control(void *arg)
{
	t_control	*controller;

	controller = (t_control *) arg;
	while (1)
	{
		//printf("[CONTROLLER]\nGOAL=%d || CURRENT=%d\n", controller->compile_goal, controller->nb_compiles);
		if (controller->nb_compiles >= controller->compile_goal)
		{
			controller->active = false;
			printf("Mission accomplished\n");
			break;
		}

	}
	return NULL;
}

void	*timer(void *arg)
{
	t_control	*controller;

	controller = (t_control *)arg;
	gettimeofday(&controller->start_time, NULL);
	while(1)
	{
		gettimeofday(&controller->current_time, NULL);
		controller->time = (long long) (controller->current_time.tv_sec - controller->start_time.tv_sec) * 1000000 + (controller->current_time.tv_usec - controller->start_time.tv_usec);
	}
	return NULL;
}

void	print_info(t_printer printer)
{
	if (*printer.active == true)
		printf("[Printer %d] || Round [%d]|| Time[%lld] || Compiles[%d]\n", printer.id, printer.rounds + 1, *printer.time / 1000, *printer.nb_compiles + 1);

}
void	*print(void *arg)
{
	t_printer	printer;

	printer = *(t_printer *) arg;
	while (1)
	{
		if (*printer.active == false)
			break;
		pthread_mutex_lock(printer.mutex);
		print_info(printer);
		printer.rounds += 1;
		*printer.nb_compiles += 1;
		pthread_mutex_unlock(printer.mutex);
		usleep(1000);
	}
	return NULL;
}

int main(void)
{
	pthread_t	timer_thread;
	t_control	controller;
	t_printer	*printers;
	int		nb_printers;

	nb_printers = 5;
	controller.time = 0;
	controller.compile_goal = 200;
	controller.nb_compiles = 0;
	pthread_mutex_init(&controller.mutex, NULL);
	printers = malloc(sizeof(t_printer) * nb_printers);
	controller.active = true;
	for (int i = 0; i < nb_printers; i++)
	{
		printers[i].id = i;
		printers[i].time = &controller.time;
		printers[i].rounds = 0;
		printers[i].nb_compiles = &controller.nb_compiles;
		printers[i].mutex = &controller.mutex;
		printers[i].active = &controller.active;
	}
	pthread_create(&timer_thread, NULL, timer, (void *) &controller);
	pthread_create(&controller.thread, NULL, control, (void *) &controller);
	for (int i = 0; i < nb_printers; i++)
		pthread_create(&printers[i].thread, NULL, print, (void *) &printers[i]);
	pthread_join(controller.thread, NULL);
	for (int i = 0; i < nb_printers; i++)
		pthread_join(printers[i].thread, NULL);
	free(printers);
	return 0;
}

