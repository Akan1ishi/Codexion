#include <sys/time.h>
#include <pthread.h>
#include <stdio.h>
#include <unistd.h>
#include <stdlib.h>

typedef struct s_control
{
	pthread_t	thread;
	pthread_mutex_t	mutex;
	long long current_time;
	long long	start_time;
	int	goal;
	int	current;
}	t_control;

typedef struct s_printer
{
	pthread_mutex_t	*mutex;
	pthread_t	thread;
	int	id;
	int rounds;
	long long *current_time;
	int *nb_compiles;
}t_printer;

void	*control(void *arg)
{
	t_control controller;

	controller = *(t_control *) arg;
	while (1)
	{
		if (*&controller.current >= controller.goal)
			break;
	}
	return NULL;
}

void	*timer(void *arg)
{
	t_control	controller;
	struct	timeval	tz;

	controller = *(t_control *)arg;
	gettimeofday(&tz, NULL);
	*&controller.start_time = (long long) tz.tv_sec * 1000;
	while(1)
	{
		gettimeofday(&tz, NULL);
		*&controller.current_time = (long long) (tz.tv_sec * 1000 ) - controller.start_time;
	}
	return NULL;
}

void	*print(void *arg)
{
	t_printer	printer;

	printer = *(t_printer *) arg;
	while (1)
	{
		printf("[Printer %d] || Round [%d]|| Time[%lld]\n", printer.id, printer.rounds + 1, *printer.current_time / 1000);
		pthread_mutex_lock(printer.mutex);
		*&printer.nb_compiles += 1;
		pthread_mutex_unlock(printer.mutex);
	}
	return NULL;
}

int main(void)
{
	pthread_t	timer_thread;
	t_control	controller;
	t_printer	*printers;
	int		nb_printers;

	nb_printers = 1;
	controller.current_time = 0;
	controller.start_time = 0;
	controller.current = 0;
	controller.goal = 10;
	pthread_mutex_init(&controller.mutex, NULL);
	printers = malloc(sizeof(t_printer) * nb_printers);
	for (int i = 0; i < nb_printers; i++)
	{
		printers[i].id = i;
		printers[i].current_time = &controller.current_time;
		printers[i].rounds = 0;
		printers[i].nb_compiles = &controller.current;
		printers[i].mutex = &controller.mutex;
	}
	pthread_create(&timer_thread, NULL, timer, (void *) &controller);
	pthread_create(&controller.thread, NULL, control, (void *) &controller);
	for (int i = 0; i < nb_printers; i++)
		pthread_create(&printers[i].thread, NULL, print, (void *) &printers[i]);
	pthread_join(controller.thread, NULL);
	for (int i = 0; i < nb_printers; i++)
		pthread_exit(printers[i].thread);
	pthread_exit(timer_thread);
	free(printers);
	return 0;
}

